generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id        String   @id @default(uuid())
  name      String
  industry  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites         Site[]
  opportunities Opportunity[]
  contacts      Contact[]
}

model Site {
  id        String   @id @default(uuid())
  companyId String
  name      String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets  Asset[]
}

model Contact {
  id        String   @id @default(uuid())
  companyId String
  name      String
  title     String
  email     String
  phone     String
  score     Int      @default(0) // Lead Score
  behavior  String?  // Recent behavior, e.g., "Tải file bản vẽ"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Asset {
  id                  String   @id @default(uuid())
  siteId              String
  serialNumber        String
  type                String
  capacity            String
  status              String   @default("Hoạt động")
  acceptanceDate      DateTime
  nextMaintenanceDate DateTime
  warrantyExpiry      DateTime?
  drawingUrl          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  site                Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  maintenanceRecords  MaintenanceRecord[]
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  assetId     String
  date        DateTime
  description String
  technician  String
  createdAt   DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id        String   @id @default(uuid())
  companyId String
  title     String
  value     Float    @default(0)
  stage     String   @default("Tìm kiếm")
  closeDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
